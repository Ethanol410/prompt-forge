# Analytics PostHog (optionnel). Si absent, l'analytics est simplement désactivée.
# Le token de projet PostHog (phc_...) est PUBLIC et « write-only » (pas un secret) :
# il sert uniquement à ENVOYER des events. À définir aussi dans les variables d'env Vercel.
VITE_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# EU: https://eu.i.posthog.com  |  US: https://us.i.posthog.com
VITE_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
