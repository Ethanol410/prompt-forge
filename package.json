{
  "name": "promptforge",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "PromptForge — générateur de meilleur prompt (BYOK / modèle local). Monorepo web + desktop.",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "typecheck": "tsc --build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^9.17.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
